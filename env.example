# Copy to .env and fill in values — never commit .env to git

# Django
SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
POSTGRES_DB=appdb
POSTGRES_USER=appuser
